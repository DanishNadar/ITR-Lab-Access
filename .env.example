# ================================================================
# Elevate Underground Lab Access - Environment Variables
# Copy this file to .env.local and fill in your values
# ================================================================

# ── Database (Neon Postgres via Vercel) ──────────────────────────
# How to get this:
#   Option A (Vercel-managed): Vercel Dashboard → Storage → Create Database → Postgres
#     Then: Settings → Environment Variables → copy DATABASE_URL
#   Option B (Neon directly): neon.tech → Create Project → Connection String
#
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ── Email (Nodemailer / SMTP) ────────────────────────────────────
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
# For SendGrid: use smtp.sendgrid.net, port 587, user=apikey, pass=<API_KEY>
#
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here

# Override the recipient for lab request notifications
NOTIFICATION_EMAIL=dnadar@hawk.illinoistech.edu

# ── Admin Auth ────────────────────────────────────────────────────
# Change this to something strong before deploying
# Generate: openssl rand -base64 24
ADMIN_PASSWORD=change-me-before-deploying

# ── Discord Bot ───────────────────────────────────────────────────
# Generate: openssl rand -hex 32
DISCORD_BOT_API_KEY=your-bot-api-key-here
